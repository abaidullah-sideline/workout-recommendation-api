# Supabase — base URL only (no /rest/v1 suffix)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (Settings → API → service_role)
SUPABASE_SERVICE_KEY=eyJhbGci...

# Google Gemini API key (aistudio.google.com)
GEMINI_API_KEY=AIza...

# Comma-separated origins allowed by CORS (use * only in dev)
ALLOWED_ORIGINS=https://yourfrontend.com,https://yourapp.vercel.app
